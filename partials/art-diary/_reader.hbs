{{!-- Art Diary reader. Used by:
       - page-art-diary.hbs (landing on /art-diary/, first entry active)
       - post.hbs when primary_tag is "art-diary" (canonical post URL — JS
         reads the URL slug and activates the matching entry on load).
     Each entry carries data-slug so archive-reader.js can match against
     window.location.pathname when bootstrapping. --}}

<script>document.body.classList.add('has-archive-reader', 'art-diary-bg');</script>

<main id="main" class="archive-page art-diary-page">

  {{#get "posts" filter="tag:art-diary" limit="all"}}

  <div class="archive-reader" id="archiveReader">

    <div class="archive-watermark">
      {{> "site-wordmark"}}
      <h1 class="archive-watermark-text">Art Diary</h1>
    </div>

    {{#foreach posts}}
    <article class="archive-entry{{#if @first}} is-active{{/if}}" data-index="{{@index}}" data-slug="{{slug}}">

      <div class="archive-entry-image">
        {{#if feature_image}}
          <img
            srcset="{{img_url feature_image size="s"}} 600w, {{img_url feature_image size="m"}} 800w, {{img_url feature_image size="l"}} 1200w"
            sizes="50vw"
            src="{{img_url feature_image size="l"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="{{#if @first}}eager{{else}}lazy{{/if}}"
          />
        {{else}}
          <div class="archive-entry-no-image"></div>
        {{/if}}
        {{> "feature-image-caption"}}
      </div>

      <div class="archive-entry-content">
        <div class="archive-entry-text">
          <h2 class="archive-entry-title">
            <a href="{{url}}">{{title}}</a>
          </h2>
          <div class="archive-entry-body">
            {{{content}}}
          </div>
        </div>
      </div>

    </article>
    {{/foreach}}

    {{!-- Controls --}}
    <div class="archive-controls" id="archiveControls">
      <button class="archive-toggle-index" id="archiveToggleIndex" aria-label="View all entries">
        <svg width="22" height="14" viewBox="0 0 32 23" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9.55556 1.5H30.5M9.55556 11.5H30.5M9.55556 21.5H30.5M1.5 1.5H1.51611M1.5 11.5H1.51611M1.5 21.5H1.51611" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="archive-nav-controls">
        <button class="archive-prev" id="archivePrev" aria-label="Previous entry" disabled>
          <svg width="10" height="20" viewBox="0 0 13 23" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11.25 21.25L1.25 11.25L11.25 1.25" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <span class="archive-counter" id="archiveCounter">1 / 1</span>
        <button class="archive-next" id="archiveNext" aria-label="Next entry">
          <svg width="10" height="20" viewBox="0 0 13 23" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11.25 21.25L1.25 11.25L11.25 1.25" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    {{!-- Index overlay --}}
    <div class="archive-index-overlay" id="archiveIndex" aria-hidden="true">
      <button class="archive-index-close" id="archiveIndexClose" aria-label="Back to reader">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="archive-index-list">
        {{#foreach posts}}
        <a class="archive-index-item" href="{{url}}">
          <span class="archive-index-title-text">{{title}}</span>
          <span class="archive-index-date">{{date format="MMM D, YYYY"}}</span>
        </a>
        {{/foreach}}
      </div>
    </div>

  </div>{{!-- end .archive-reader --}}

  {{/get}}

</main>

<script src="{{asset "js/archive-reader.js"}}"></script>
<script>
  (function () {
    var items = document.querySelectorAll('#archiveIndex .archive-index-item');
    var total = items.length;
    for (var i = 0; i < total; i++) {
      items[i].setAttribute('data-num', total - i);
    }
  })();
</script>
