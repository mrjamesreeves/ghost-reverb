{{!-- Midnight Radio episode reader.
     Used by post.hbs when primary_tag is "midnight-radio".

     Layout: image left (with MR number + title overlaid in top-left),
     scrolling prose right, filmstrip of all episodes across the bottom.
     The filmstrip auto-centers on the current episode at load — small
     alt-nav for jumping around the catalog without leaving the reader. --}}

<script>document.body.classList.add('has-archive-reader', 'has-mr-episode');</script>

<main id="main" class="archive-page mr-episode-page">

  <div class="archive-reader mr-episode" id="mrEpisode">

    <article class="archive-entry is-active" data-slug="{{slug}}">

      {{!-- LEFT: image with MR number + title overlay --}}
      <div class="archive-entry-image mr-episode-cover">
        {{#if feature_image}}
          <img
            srcset="{{img_url feature_image size="s"}} 600w, {{img_url feature_image size="m"}} 800w, {{img_url feature_image size="l"}} 1200w"
            sizes="50vw"
            src="{{img_url feature_image size="l"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="eager"
          />
        {{/if}}

        <div class="mr-episode-cover-text">
          {{> "site-wordmark"}}
          {{!-- Episode number eyebrow. We emit one .episode-number span
               per internal tag; the site-wide resolver in footer.hbs only
               fills text on spans whose data-ep starts with `hash-mr-`,
               so non-MR internal tags stay empty and CSS (:empty) hides
               them. Ghost's match helper doesn't reliably anchor regex,
               which is why we don't filter in the template itself. --}}
          <p class="mr-episode-eyebrow">
            <span class="mr-episode-eyebrow-prefix">Midnight Radio</span>
            {{#foreach tags visibility="internal"}}
              <span class="episode-number" data-ep="{{slug}}"></span>
            {{/foreach}}
          </p>
          <h1 class="mr-episode-title">{{title}}</h1>

          {{!-- Slot for the cloned "Download | Podcast" link pair.
               mr-filmstrip.js finds h4#download-podcast in the post body
               and clones it here (keeping the original in place at the
               bottom of the post). Stays empty if the post has none. --}}
          <div class="mr-episode-links" id="mrEpisodeLinksSlot"></div>
        </div>

        {{> "feature-image-caption"}}
      </div>

      {{!-- RIGHT: date + excerpt + body, plus sticky controls/gradient --}}
      <div class="archive-entry-content mr-episode-body">
        <div class="archive-entry-text">
          <p class="mr-episode-date">{{date format="MMMM D, YYYY"}}</p>
          {{#if custom_excerpt}}
            <h2 class="mr-episode-excerpt">{{custom_excerpt}}</h2>
          {{/if}}
          <div class="archive-entry-body mr-episode-content">
            {{content}}
          </div>
        </div>

        {{!-- Sticky controls. Stay pinned to the bottom of the right pane
             as the prose scrolls. The bar's own background carries a
             gradient fade above it so text scrolls under softly rather
             than clipping at a hard edge. --}}
        <div class="mr-episode-controls">
          <a class="mr-episode-index" href="/radio/" aria-label="View all Midnight Radio episodes">
            <svg width="32" height="23" viewBox="0 0 32 23" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9.55556 1.5H30.5M9.55556 11.5H30.5M9.55556 21.5H30.5M1.5 1.5H1.51611M1.5 11.5H1.51611M1.5 21.5H1.51611" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <div class="mr-episode-nav">
            {{#prev_post in="primary_tag"}}
              <a class="mr-episode-prev" href="{{url}}" aria-label="Previous episode">
                <svg width="13" height="23" viewBox="0 0 13 23" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M11.25 21.25L1.25 11.25L11.25 1.25" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {{else}}
              <span class="mr-episode-prev is-disabled" aria-label="No previous episode">
                <svg width="13" height="23" viewBox="0 0 13 23" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M11.25 21.25L1.25 11.25L11.25 1.25" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            {{/prev_post}}
            {{#next_post in="primary_tag"}}
              <a class="mr-episode-next" href="{{url}}" aria-label="Next episode">
                <svg width="13" height="23" viewBox="0 0 13 23" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1.75 1.25L11.75 11.25L1.75 21.25" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {{else}}
              <span class="mr-episode-next is-disabled" aria-label="No next episode">
                <svg width="13" height="23" viewBox="0 0 13 23" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1.75 1.25L11.75 11.25L1.75 21.25" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            {{/next_post}}
          </div>
        </div>
      </div>

    </article>

  </div>{{!-- end .archive-reader --}}

  {{!-- FILMSTRIP: every MR episode as a cover thumb, current centered
       on load. No titles — they live inside the artwork. Each thumb gets
       a hidden block of internal-tag slugs; mr-filmstrip.js parses the
       hash-mr-N tag, zero-pads, and sets the cover src to
       /assets/mr/MR{NN}.webp. --}}
  <nav class="mr-filmstrip" id="mrFilmstrip" aria-label="All Midnight Radio episodes">
    <div class="mr-filmstrip-track">
      {{#get "posts" filter="tag:midnight-radio" limit="all" order="published_at desc" include="tags"}}
        {{#foreach posts}}
        <a href="{{url}}" class="mr-filmstrip-thumb" data-slug="{{slug}}" aria-label="{{title}}">
          <img class="mr-filmstrip-cover" alt="" loading="lazy">
          <span class="mr-filmstrip-tags" hidden>
            {{#foreach tags visibility="internal"}}
              <span data-ep="{{slug}}"></span>
            {{/foreach}}
          </span>
        </a>
        {{/foreach}}
      {{/get}}
    </div>
  </nav>

</main>

<script src="{{asset "js/mr-filmstrip.js"}}"></script>
