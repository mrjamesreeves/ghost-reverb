{{!-- The dial: left-rail list of every post in the current category.
     Expects to be rendered inside a block where `posts` holds the
     FULL ordered list (a {{#get}} in post.hbs / channel templates).

     Dumb list by design — zen.js marks the entry matching the current
     URL (.is-current), vertically centers it in the 60vh window, and
     wires the prev/next arrows from its neighbors. White fade
     gradients at both ends come from CSS. --}}

<nav class="dial" id="dial" aria-label="More in this category">
  <div class="dial-window">
    <div class="dial-list" id="dialList">
      {{#foreach posts}}
        {{!-- Internal-tag spans only render when the caller's #get
             included tags (the MR queries do). zen.js reads hash-mr-N
             and prefixes the title: "49. The Shimmer". --}}
        <a href="{{url}}" data-slug="{{slug}}">{{#foreach tags visibility="internal"}}<span data-ep="{{slug}}" hidden></span>{{/foreach}}{{title}}</a>
      {{/foreach}}
    </div>
  </div>
</nav>
