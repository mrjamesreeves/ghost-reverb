{{!-- The dial: left-rail list of every post in the current category.
     Expects to be rendered inside a block where `posts` holds the
     FULL ordered list (a {{#get}} in post.hbs / channel templates).

     Params (all optional):
       sectionTitle / sectionUrl — clickable header INSIDE the window,
         sitting directly above the first entry (black, 25px rule),
         linking back to the section index. It scrolls with the list.
       numbered=true — zen.js prefixes each entry with its position,
         oldest = 1 (used by dreams / art / favorites).

     Dumb list by design — zen.js marks the entry matching the current
     URL (.is-current), vertically centers it in the window, and
     wires the prev/next arrows from its neighbors. White fade
     gradients at both ends come from CSS. --}}

<nav class="dial" id="dial" aria-label="More in this category">
  <div class="dial-window">
    {{#if sectionTitle}}
      <a class="dial-title" href="{{@site.url}}{{sectionUrl}}">{{sectionTitle}}</a>
    {{/if}}
    <div class="dial-list" id="dialList"{{#if numbered}} data-numbered{{/if}}>
      {{#if archiveEntries}}
        {{!-- Archive: >100 posts — paged queries live in the entries
             partial (Ghost 6 caps #get at 100). --}}
        {{> "dial-archive-entries"}}
      {{else}}
        {{#foreach posts}}
          {{> "dial-entry"}}
        {{/foreach}}
      {{/if}}
    </div>
  </div>
</nav>
