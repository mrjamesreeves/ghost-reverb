{{!-- Wordmark + hover-reveal nav.

     Resting: only the wordmark, at 15% black. Hovering the header zone
     (desktop) or tapping the wordmark (touch) adds .is-open, which
     fades in the link columns + Midnight Radio CTA and darkens the
     wordmark to full black. zen.js owns the touch toggle; the :hover
     path is pure CSS so it works without JS.

     The subscribe CTA renders only for non-members — members see
     nothing in that slot. Button opens Ghost Portal signup. --}}

<header class="site-top" id="siteTop">
  <div class="site-top-inner">

    <a class="wordmark" id="wordmark" href="{{@site.url}}/">James A. Reeves</a>

    <nav class="site-nav" id="siteNav" aria-label="Site">
      <div class="site-nav-col">
        <a href="{{@site.url}}/radio/">Midnight Radio</a>
        <a href="{{@site.url}}/dreams/">Dream Inventory</a>
        <a href="{{@site.url}}/art-diary/">Art Diary</a>
        <a href="{{@site.url}}/spite/">Spite</a>
      </div>
      <div class="site-nav-col">
        <a href="{{@site.url}}/public-works/">Public Works</a>
        <a href="{{@site.url}}/favorites/">Favorite Things</a>
        <a href="{{@site.url}}/instructions/">Instructions for Myself</a>
        <a href="{{@site.url}}/about/">About</a>
      </div>

      {{#unless @member}}
      <div class="site-nav-cta">
        <p class="site-nav-cta-title">Join Midnight Radio</p>
        <p class="site-nav-cta-blurb">Notes on surviving the 21st century and a mixtape delivered &rsquo;round midnight on the 1st and 15th of the month.</p>
        <button class="site-nav-subscribe" data-portal="signup">Subscribe</button>
      </div>
      {{/unless}}
    </nav>

  </div>
</header>
