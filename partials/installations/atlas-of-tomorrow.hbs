{{!-- Atlas of Tomorrow — stub.
     Renders a single intro slide from the post's own content / feature_image.
     Flesh out with press quote + media slides matching the after-the-end
     partial structure when ready. The deck partial (_deck.hbs) references
     this file by slug; removing it again will fail theme validation. --}}

<article class="archive-entry archive-entry--intro is-active" data-index="0">

  <div class="archive-entry-image">
    {{#if feature_image}}
      <img
        src="{{img_url feature_image size="xl"}}"
        alt="{{title}}"
        loading="eager"
      />
    {{/if}}
  </div>

  <div class="archive-entry-content">
    <div class="archive-entry-text">
      <h1 class="archive-entry-title">{{title}}</h1>
      <div class="archive-entry-body">
        {{{content}}}
      </div>
    </div>
  </div>

</article>
