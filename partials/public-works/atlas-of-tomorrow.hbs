{{!-- The Atlas of Tomorrow — slides.
     Inherits {{title}}, {{{content}}}, {{feature_image}} from the parent
     post.hbs's #post block.

     Media slide images are local under /assets/public-works/atlas-of-tomorrow/.
     To grow the deck: drop more atlas-N.webp into that folder and
     append matching <article> blocks below (with data-index incremented).

     To add a press quote: uncomment the block below the intro's
     archive-entry-content opening tag and replace TK with the quote
     and publication. To add a text slide later in the deck, see the
     archive-entry--text pattern documented in CSS comments. --}}

{{!-- ── INTRO SLIDE ───────────────────────────────────────────────────── --}}
<article class="archive-entry archive-entry--intro is-active" data-index="0">

  <div class="archive-entry-image">
    {{#if feature_image}}
      <img src="{{img_url feature_image size="xl"}}" alt="{{title}}" loading="eager" />
    {{/if}}
    {{> "feature-image-caption"}}
  </div>

  <div class="archive-entry-content">
    {{!-- Press quote — uncomment + fill in when ready.
    <blockquote class="archive-press-quote">
      &ldquo;Quote text here.&rdquo;
    </blockquote>
    <p class="archive-press-source">Publication Name</p>
    --}}

    <div class="archive-entry-text">
      <h1 class="archive-entry-title">{{title}}</h1>
      <div class="archive-entry-body">
        {{{content}}}
      </div>
    </div>
  </div>

</article>

{{!-- ── MEDIA SLIDES ───────────────────────────────────────────────────── --}}

<article class="archive-entry archive-entry--media" data-index="1" data-caption="Photo by TK">
  <div class="archive-entry-image archive-entry-image--full">
    <img loading="lazy" alt="" src="/assets/public-works/atlas-of-tomorrow/atlas-1.webp" />
  </div>
</article>

