{{!-- Public Works slide deck.
     Loaded from post.hbs whenever a post's primary tag is `public-works`.
     This partial expects to be rendered inside a {{#post}} context.
     Pulls title / body / feature_image from Ghost; press quote, media
     slides and captions live in partials/public-works/{slug}.hbs (one
     per project).

     Reader chrome — matches the Figma:
       - Watermark: small "Public Works" stamp top-left, muted gray-on-image
       - Caption capsule: bottom-left, populated from the active slide's
         data-caption attribute. Hidden when the slide has none.
       - Controls capsule: bottom-right. Index icon = link to /public-works/
         (the dark TOC page). Prev/next chevrons advance within this deck.
         Cross-project rollthrough wires up in Phase 2d.

     Both the caption and controls use the shared .pw-capsule visual
     pattern (10px radius, 50% white, 10px backdrop-blur) so they read
     cleanly over any underlying content. --}}

<script>document.body.classList.add('has-archive-reader', 'dreams-bg', 'public-works-bg');</script>

<main id="main" class="archive-page public-works-page">

  <div class="archive-reader" id="archiveReader" data-current-slug="{{slug}}">

    {{!-- Watermark stack: site wordmark (link to home) above the
         section watermark (link to the dark TOC index). The wrapper
         is a div, not an anchor, so the two interior links can both
         exist without nesting. --}}
    <div class="public-works-watermark">
      {{> "site-wordmark"}}
      <a class="public-works-watermark-link" href="{{@site.url}}/public-works/" aria-label="View all public works">
        <h1 class="public-works-watermark-text">Public<br>Works</h1>
      </a>
    </div>

    {{!-- Per-project partial: intro slide + media slides for this post.
         Add a new {{#match}} branch for each new project's partial. --}}
    {{#match slug "after-the-end"}}{{> "public-works/after-the-end"}}{{/match}}
    {{#match slug "light-the-barricades"}}{{> "public-works/light-the-barricades"}}{{/match}}
    {{#match slug "the-nightly-news"}}{{> "public-works/the-nightly-news"}}{{/match}}
    {{#match slug "monument-anxious-hopeful"}}{{> "public-works/monument-anxious-hopeful"}}{{/match}}
    {{#match slug "atlas-of-tomorrow"}}{{> "public-works/atlas-of-tomorrow"}}{{/match}}

    {{!-- Caption capsule. Populated by public-works-reader.js from each
         slide's data-caption attribute. Element is hidden via the
         [hidden] attribute when the active slide carries no caption. --}}
    <div class="pw-caption pw-capsule" id="archiveCaption" aria-live="polite" hidden></div>

    {{!-- Controls capsule. Index icon is a real <a> (right-click /
         cmd-click semantics work, no JS dependency for the navigation).
         Prev/next chevrons hand off to public-works-reader.js. --}}
    <div class="pw-controls pw-capsule">
      <a class="pw-controls-btn pw-controls-index" href="{{@site.url}}/public-works/" aria-label="View all public works">
        <svg width="22" height="16" viewBox="0 0 32 23" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9.55556 1.5H30.5M9.55556 11.5H30.5M9.55556 21.5H30.5M1.5 1.5H1.51611M1.5 11.5H1.51611M1.5 21.5H1.51611" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <button class="pw-controls-btn pw-controls-prev" id="archivePrev" aria-label="Previous slide">
        <svg width="10" height="16" viewBox="0 0 13 23" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M11.25 21.25L1.25 11.25L11.25 1.25" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <span class="pw-controls-counter" id="archiveCounter" aria-live="polite">1 / 1</span>
      <button class="pw-controls-btn pw-controls-next" id="archiveNext" aria-label="Next slide">
        <svg width="10" height="16" viewBox="0 0 13 23" fill="none" xmlns="http://www.w3.org/2000/svg" style="transform: scaleX(-1);">
          <path d="M11.25 21.25L1.25 11.25L11.25 1.25" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

  </div>{{!-- end .archive-reader --}}

</main>

{{!-- Project list for cross-project chevron navigation. Phase 2d will
     read this to drive the rollthrough behavior — at last slide of
     project N, next-arrow advances to first slide of project N+1, and
     wraps from last project back to first. --}}
<script type="application/json" id="publicWorksList">
[{{#get "posts" filter="tag:public-works" limit="all" order="published_at desc"}}{{#foreach posts}}{"slug":"{{slug}}","url":"{{url}}","title":"{{title}}"}{{#unless @last}},{{/unless}}{{/foreach}}{{/get}}]
</script>

<script src="{{asset "js/public-works-reader.js"}}"></script>
