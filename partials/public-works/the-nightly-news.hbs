{{!-- The Nightly News — slides.
     Inherits {{title}}, {{{content}}}, {{feature_image}} from the parent
     post.hbs's #post block.

     Media slide images are local under /assets/public-works/the-nightly-news/.
     To grow the deck: drop more nightly-N.webp into that folder and
     append matching <article> blocks below (with data-index incremented).

     To add a press quote: uncomment the block below the intro's
     archive-entry-content opening tag and replace TK with the quote
     and publication. To add a text slide later in the deck, see the
     archive-entry--text pattern documented in CSS comments. --}}

{{!-- ── INTRO SLIDE ───────────────────────────────────────────────────── --}}
<article class="archive-entry archive-entry--intro is-active" data-index="0">

  <div class="archive-entry-image">
    {{#if feature_image}}
      <img src="{{img_url feature_image size="xl"}}" alt="{{title}}" loading="eager" />
    {{/if}}
    {{> "feature-image-caption"}}
  </div>

  <div class="archive-entry-content">
    {{!-- Press quote — uncomment + fill in when ready.
    <blockquote class="archive-press-quote">
      &ldquo;Quote text here.&rdquo;
    </blockquote>
    <p class="archive-press-source">Publication Name</p>
    --}}

    <div class="archive-entry-text">
      <h1 class="archive-entry-title">{{title}}</h1>
      <div class="archive-entry-body">
        {{{content}}}
      </div>
    </div>
  </div>

</article>

{{!-- ── MEDIA SLIDES ───────────────────────────────────────────────────── --}}

<article class="archive-entry archive-entry--media" data-index="1" data-caption="Photo by Pomegranate">
  <div class="archive-entry-image archive-entry-image--full">
    <img loading="lazy" alt="" src="/assets/public-works/the-nightly-news/nightly-1.webp" />
  </div>
</article>

<article class="archive-entry archive-entry--media" data-index="2" data-caption="Video still">
  <div class="archive-entry-image archive-entry-image--full">
    <img loading="lazy" alt="" src="/assets/public-works/the-nightly-news/nightly-2.webp" />
  </div>
</article>

<article class="archive-entry archive-entry--media archive-entry--video" data-index="3" data-caption="Video • 6:25" data-vimeo-id="820396697">
  <div class="archive-entry-image archive-entry-image--full">
    <img loading="lazy" alt="" src="/assets/public-works/the-nightly-news/nightly-2.webp" />
    <div class="pw-video-play" aria-hidden="true">
      <svg width="36" height="42" viewBox="0 0 36 42" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M36 21L0 42V0L36 21Z" fill="currentColor"/>
      </svg>
    </div>
  </div>
</article>