{{!< default}}

{{!-- /welcome/ — single-reader view.
     Saint Jerome left, page body right (scrolls). Body content
     comes from the Ghost editor for this page — "what Midnight
     Radio is" stays editable without theme edits.

     Image source:
       1. Page's feature_image (set in Ghost admin → Welcome → Image).
       2. Falls back to /assets/mr/mr-header.webp (Caravaggio's
          Saint Jerome) — the show's long-running visual ID.

     The episodes index that used to live here is gone; that's
     /radio/'s job now. Keeping /welcome/ focused on the "about
     this show" register matches About's treatment. --}}

<script>document.body.classList.add('has-archive-reader');</script>

{{#post}}

<main id="main" class="archive-page archive-page--single welcome-page">

  <div class="archive-reader archive-reader--single" id="archiveReader">

    <div class="archive-watermark archive-watermark--static">
      {{> "site-wordmark"}}
      <h1 class="archive-watermark-text">Midnight<br>Radio</h1>
    </div>

    <article class="archive-entry is-active" data-slug="{{slug}}">

      <div class="archive-entry-image">
        {{#if feature_image}}
          <img
            src="{{img_url feature_image size="xl"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="eager"
          />
        {{else}}
          <img
            src="{{asset "/mr/mr-header.webp"}}"
            alt="Caravaggio, Saint Jerome in His Study (1605)"
            loading="eager"
          />
        {{/if}}
        {{> "feature-image-caption"}}
      </div>

      <div class="archive-entry-content">
        <div class="archive-entry-text">
          <div class="archive-entry-body">
            {{{content}}}
          </div>
        </div>
      </div>

    </article>

  </div>{{!-- /.archive-reader --}}

</main>

{{/post}}
