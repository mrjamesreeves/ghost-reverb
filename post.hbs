{{!< default}}

{{#post}}

{{!-- ── DISPATCH BY PRIMARY TAG ─────────────────────────────────────────
     The reader sections (Dreams, Art Diary, Installations) all have
     dedicated experiences instead of the standard long-read post layout.
     Each is a partial; canonical post URLs route here, primary_tag picks
     the right one. Anything else falls through to the default layout.
─────────────────────────────────────────────────────────────────────── --}}
{{#match primary_tag.slug "dreams"}}
  {{> "dreams/_reader"}}
{{else}}{{#match primary_tag.slug "art-diary"}}
  {{> "art-diary/_reader"}}
{{else}}{{#match primary_tag.slug "favorites"}}
  {{> "favorites/_reader"}}
{{else}}{{#match primary_tag.slug "installations"}}
  {{> "installations/_deck"}}
{{else}}{{#match primary_tag.slug "midnight-radio"}}
  {{> "midnight-radio/_episode"}}
{{else}}

{{!-- ── DEFAULT: SINGLE-POST READER ──────────────────────────────────────
     Any post that isn't part of one of the dispatched collections
     (dreams, art-diary, favorites, installations) renders in a stripped
     reader — image left, scrollable text right, no prev/next, no TOC.
     Book-like single artifact. The collection readers stay distinct
     because they have sibling navigation; this one has no nav by design.
─────────────────────────────────────────────────────────────────────── --}}
<script>document.body.classList.add('has-archive-reader');</script>

<main id="main" class="archive-page archive-page--single">

  <div class="archive-reader archive-reader--single" id="archiveReader">

    {{#if primary_tag}}
    <div class="archive-watermark archive-watermark--static">
      <h1 class="archive-watermark-text">{{primary_tag.name}}</h1>
    </div>
    {{/if}}

    <article class="archive-entry is-active" data-index="0" data-slug="{{slug}}">

      <div class="archive-entry-image">
        {{#if feature_image}}
          <img
            srcset="{{img_url feature_image size="s"}} 600w, {{img_url feature_image size="m"}} 800w, {{img_url feature_image size="l"}} 1200w"
            sizes="50vw"
            src="{{img_url feature_image size="l"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="eager"
          />
        {{else}}
          <div class="archive-entry-no-image"></div>
        {{/if}}
        {{> "feature-image-caption"}}
      </div>

      <div class="archive-entry-content">
        <div class="archive-entry-text">
          <h2 class="archive-entry-title">{{title}}</h2>
          <div class="archive-entry-body">
            {{content}}
          </div>
        </div>
      </div>

    </article>

  </div>{{!-- end .archive-reader --}}

</main>

{{/match}}{{/match}}{{/match}}{{/match}}{{/match}}

{{/post}}
