{{!< default}}

{{!-- Canonical post URL: /{slug}/.

     Renders the post (post-view picks the MR or standard variant),
     then the dial (+ cover grid on MR) for the post's section.

     TWO HARD RULES learned the slow way:
     1. {{#get}} does NOT interpolate handlebars inside its filter
        param — not route context, not post-scope attributes. Fails
        silently. Literal filters only.
     2. primary_tag is EMPTY when a post's first tag is internal
        (e.g. #mr-45 sorted before midnight-radio) — so dispatch on
        {{#has tag="..."}}, which checks all tags order-independently.
        And {{#has}} matches tag NAMES (case-insensitive), not slugs —
        so these use the display names from Ghost admin ("Art", not
        "art-diary"). Renaming a tag in admin breaks its dispatch.
     A post in none of the five sections gets no dial. --}}

{{#post}}

  {{> "post-view"}}

  {{#has tag="Midnight Radio"}}
    {{#get "posts" filter="tag:midnight-radio" limit="all" order="published_at desc" include="tags"}}
      {{> "dial"}}
      {{> "mr-grid"}}
    {{/get}}
  {{else}}{{#has tag="Dreams"}}
    {{#get "posts" filter="tag:dreams" limit="all" order="published_at desc"}}
      {{> "dial" sectionTitle="Dream Inventory" sectionUrl="/dreams/" numbered=true}}
    {{/get}}
  {{else}}{{#has tag="Art"}}
    {{#get "posts" filter="tag:art-diary" limit="all" order="published_at desc"}}
      {{> "dial" sectionTitle="Art Diary" sectionUrl="/art-diary/" numbered=true}}
    {{/get}}
  {{else}}{{#has tag="favorites"}}
    {{#get "posts" filter="tag:favorites" limit="all" order="published_at desc"}}
      {{> "dial" sectionTitle="Favorite Things" sectionUrl="/favorites/" numbered=true}}
    {{/get}}
  {{else}}{{#has tag="Public Works"}}
    {{#get "posts" filter="tag:public-works" limit="all" order="published_at desc"}}
      {{> "dial" sectionTitle="Public Works" sectionUrl="/public-works/"}}
    {{/get}}
  {{else}}{{#has tag="Design"}}
    {{!-- Design posts are excluded from the Archive, so no dial —
         it would mark the wrong entry current. --}}
  {{else}}
    {{!-- Everything else lives in the Archive. Its entries come from
         paged queries inside the dial (archiveEntries) — Ghost 6
         caps {{#get}} at 100 posts. --}}
    {{> "dial" sectionTitle="Archive" sectionUrl="/archive/" numbered=true archiveEntries=true}}
  {{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}

{{/post}}
