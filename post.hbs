{{!< default}}

{{!-- Canonical post URL: /{slug}/.

     Renders the post (post-view picks the MR or standard variant),
     then fetches the full sibling list for the post's primary tag to
     drive the dial + prev/next arrows (+ the cover grid on MR posts).

     The `tags:[{{primary_tag.slug}}]` filter interpolation is the
     documented Ghost related-posts pattern — it resolves because we're
     inside a {{#post}} block where primary_tag is a concrete value.
     (Interpolating route-level context like tag.slug does NOT work;
     that burned us in reverb. Post-scope attributes are fine.) --}}

{{#post}}

  {{> "post-view"}}

  {{#if primary_tag}}
    {{#get "posts" filter="tags:[{{primary_tag.slug}}]" limit="all" order="published_at desc" include="tags"}}
      {{> "dial"}}
      {{!-- ../ climbs out of the #get frame back to the post context --}}
      {{#match ../primary_tag.slug "midnight-radio"}}
        {{> "mr-grid"}}
      {{/match}}
    {{/get}}
  {{/if}}

{{/post}}
