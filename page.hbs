{{!< default}}

{{!-- Generic page (About, etc.): the standard post treatment without
     dial, meta, or arrows. Image comes from the page's feature_image
     in Ghost admin. --}}

{{#post}}

  <article class="post post--page" data-slug="{{slug}}">

    {{!-- @page.show_title_and_feature_image is the per-page toggle in
         Ghost's editor settings — respecting it is also a theme-validation
         requirement ("page features must be used"). --}}
    {{#if @page.show_title_and_feature_image}}
      {{#if feature_image}}
        <div class="post-image">
          <img
            srcset="{{img_url feature_image size="m"}} 800w, {{img_url feature_image size="l"}} 1200w, {{img_url feature_image size="xl"}} 1600w"
            sizes="(max-width: 960px) 100vw, 900px"
            src="{{img_url feature_image size="l"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="eager">
        </div>
      {{/if}}
    {{/if}}

    <div class="post-body-col">
      {{#if @page.show_title_and_feature_image}}
        <h1 class="post-title">{{title}}</h1>
      {{/if}}
      <div class="post-content">
        {{content}}
      </div>
    </div>

  </article>

{{/post}}
