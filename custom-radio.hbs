{{!< default}}

<main id="main" class="content outer radio-page">
    {{#post}}
    
    <div class="radio-hero-container">
        <div class="radio-hero-wrapper">
            <div class="image-slider">
                {{#if feature_image}}
                    <img
                        class="post-card-image bg-full-image bg-fade-in"
                        srcset="{{img_url feature_image size="xs"}} 300w, {{img_url feature_image size="s" }} 600w, {{img_url feature_image size="m" }} 800w, {{img_url feature_image size="l" }} 1200w, {{img_url feature_image size="xl" }} 1600w, {{img_url feature_image size="xxl" }} 2000w"
                        sizes="(min-width: 1600px) 1600px, 100vw"
                        src="{{img_url feature_image size="xl"}}"
                        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    />
                {{/if}}
            </div>

            <div class="radio-hero-content">
                <h5><a href="{{@site.url}}/radio">
                    Midnight Radio
                    {{#foreach tags visibility="internal"}}
                    {{#if (match slug "^hash-mr-")}}
                        <span class="episode-number" data-ep="{{slug}}"></span>
                    {{/if}}
                    {{/foreach}}</a>
                </h5>
                <h1>{{title}}</h1>
            </div>
        </div>
        {{#if feature_image_caption}}
            <div class="radio-hero-caption">
                {{feature_image_caption}}
            </div>
        {{/if}}
    </div>

    <div class="radio-content-wrapper">
        <div class="inner-wide">
            <article class="{{post_class}} post-full">
                
                <div class="post-header-content inner">
                    <div class="post-extract">
                        <h5><time datetime="{{date format='YYYY-MM-DD'}}">{{date format="LL"}}</time></h5>
                        <h2>{{{custom_excerpt}}}</h2>
                    </div>
                </div>

                <div class="post-content">
                    {{content}}
                </div>

                {{> post-meta}}

            {{#if @member}} {{else}}
            <div class="inner">
                <div class="radio-cta">
                    <p>Enjoy life and get Midnight Radio delivered to your inbox 'round midnight on the 1st and 15th of each month.</p>
                    {{> signup}}
                </div>
            </div>
            {{/if}}

            </div>
        </article>


    <!-- EPISODES -->
    <div class="inner-wide">
        <div class="grid grid-more">
            {{#get "posts" include="authors,tags,tiers" filter="tag:midnight-radio+id:-{{id}}" limit="3"}}
            {{#foreach posts visibility="all"}}
                <article>
                    <a href="{{url}}" class="post-card-link">
                    <div class="post-card bg-dark bg-full">

                        {{#if feature_image}}
                            <img
                                class="post-card-image bg-full-image bg-fade-in"
                                srcset="{{img_url feature_image size="xs"}} 300w, {{img_url feature_image size="s" }} 600w, {{img_url feature_image size="m" }} 800w, {{img_url feature_image size="l" }} 1200w, {{img_url feature_image size="xl" }} 1600w, {{img_url feature_image size="xxl" }} 2000w"
                                sizes="(min-width: 1600px) 1600px, 100vw"
                                src="{{img_url feature_image size="xl"}}"
                                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                            />
                        {{/if}}

                        <div class="post-card-inside">
                            <div class="post-card-content">          
                                <div class="big-title">
                                    <h5>
                                        Midnight Radio 
                                        {{#foreach tags visibility="internal"}}
                                        {{#if (match slug "^hash-mr-")}}
                                            <span class="episode-number" data-ep="{{slug}}"></span>
                                        {{/if}}
                                        {{/foreach}}
                                    </h5>
                                    <h2>{{title}}</h2>
                                </div>
                            </div>
                        </div>
                    </div>
                    </a>
                </article>                            

            {{/foreach}}
            {{/get}}
        </div>
    </div>

{{/post}}
</main>



