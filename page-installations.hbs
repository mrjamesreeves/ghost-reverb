{{!< default}}

{{!-- Index page at /installations/. The {{#get}} that surfaces the post list
     is wired up by the collection in routes.yaml — `posts` is in scope here.
     Single-column TOC for now; visual treatment can grow later. --}}

<script>document.body.classList.add('has-archive-reader', 'dreams-bg');</script>

<main id="main" class="archive-page installations-page installations-index-page">

  <div class="archive-watermark">
    <h1 class="archive-watermark-text">Art<br>Installations</h1>
  </div>

  <div class="installations-index">
    <ol class="installations-index-list">
      {{#foreach posts}}
      <li class="installations-index-item">
        <a class="installations-index-link" href="{{url}}">
          <span class="installations-index-num"></span>
          <span class="installations-index-title">{{title}}</span>
          <span class="installations-index-date">{{date format="MMM YYYY"}}</span>
        </a>
      </li>
      {{/foreach}}
    </ol>
  </div>

</main>

<script>
  /* Newest = highest number, matching the Dreams index pattern. */
  (function () {
    var items = document.querySelectorAll('.installations-index-item');
    var total = items.length;
    for (var i = 0; i < total; i++) {
      items[i].querySelector('.installations-index-num').textContent = total - i;
    }
  })();
</script>
