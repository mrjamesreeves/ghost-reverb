{{!< default}}

{{!-- /dreams/ — Dream Inventory channel. No landing page: renders the LATEST
     post in the tag as a full post, with the dial for everything else.
     Literal tag filter — {{#get}} can't interpolate route context. --}}

{{#contentFor "title"}}Dream Inventory — {{@site.title}}{{/contentFor}}

{{!-- Mobile-only section heading — the dial (which carries the
     section title on desktop) is hidden below 1200px. --}}
<h1 class="channel-heading">Dream Inventory</h1>

{{#get "posts" filter="tag:dreams" limit="all" order="published_at desc" include="tags"}}
  {{#foreach posts}}
    {{> "post-view" stacked=true}}
  {{/foreach}}
  {{> "dial" sectionTitle="Dream Inventory" sectionUrl="/dreams/" numbered=true}}
{{/get}}
