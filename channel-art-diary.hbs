{{!< default}}

{{!-- /art-diary/ — Art Diary channel. No landing page: renders the LATEST
     post in the tag as a full post, with the dial for everything else.
     Literal tag filter — {{#get}} can't interpolate route context. --}}

{{#contentFor "title"}}Art Diary — {{@site.title}}{{/contentFor}}

{{#get "posts" filter="tag:art-diary" limit="all" order="published_at desc" include="tags"}}
  {{#foreach posts limit="1"}}
    {{> "post-view"}}
  {{/foreach}}
  {{> "dial"}}
{{/get}}
