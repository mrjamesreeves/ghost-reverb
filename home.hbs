{{!< default}}

{{!-- Homepage. Hero = the latest Midnight Radio episode as a black
     cover block (eyebrow + title + artwork), linking to the post.
     Below: four section tiles. Footer comes from default.hbs. --}}

{{#contentFor "title"}}{{@site.title}} — {{@site.description}}{{/contentFor}}

{{#get "posts" filter="tag:midnight-radio" limit="1" order="published_at desc" include="tags"}}
  {{#foreach posts}}
  <a class="mr-hero mr-hero--link" href="{{url}}">
    <p class="mr-hero-eyebrow">
      Midnight Radio
      {{#foreach tags visibility="internal"}}<span class="episode-number" data-ep="{{slug}}"></span>{{/foreach}}
    </p>
    <h1 class="mr-hero-title">{{title}}</h1>
    {{#if feature_image}}
      <img class="mr-hero-art"
        srcset="{{img_url feature_image size="m"}} 800w, {{img_url feature_image size="l"}} 1200w, {{img_url feature_image size="xl"}} 1600w"
        sizes="(max-width: 960px) 100vw, 900px"
        src="{{img_url feature_image size="l"}}"
        alt="{{title}}" loading="eager">
    {{/if}}
  </a>
  {{/foreach}}
{{/get}}

<div class="home-tiles">
  <div class="home-tiles-row home-tiles-row--halves">
    <a class="home-tile home-tile--tall" href="{{@site.url}}/art-diary/">
      <img src="{{asset "img/home-art-diary.webp"}}" alt="" loading="lazy">
      <span class="home-tile-title">Art Diary</span>
    </a>
    <a class="home-tile home-tile--tall" href="{{@site.url}}/dreams/">
      <img src="{{asset "img/home-dream-inventory.webp"}}" alt="" loading="lazy">
      <span class="home-tile-title">Dream<br>Inventory</span>
    </a>
  </div>
  <div class="home-tiles-row home-tiles-row--split">
    <a class="home-tile home-tile--wide" href="{{@site.url}}/favorites/">
      <img src="{{asset "img/home-favorites.webp"}}" alt="" loading="lazy">
      <span class="home-tile-title">Favorite<br>Things</span>
    </a>
    <a class="home-tile home-tile--square" href="{{@site.url}}/radio/">
      <img src="{{asset "img/home-midnight-radio.webp"}}" alt="" loading="lazy">
      <span class="home-tile-title">Midnight<br>Radio</span>
    </a>
  </div>
</div>
