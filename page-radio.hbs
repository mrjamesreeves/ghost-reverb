{{!< default}}

{{!-- /radio/ — Midnight Radio landing.

     Dark gallery-style index. Header block top-left (title +
     tagline), Caravaggio's Saint Jerome to the right — long-running
     visual ID for the show. Below: filter row, then a dense grid of
     every episode cover. Each card has two layers: front shows the
     cover artwork with episode-number eyebrow + title overlaid; back
     is a black panel with the excerpt. Hover crossfades between them.

     The dark background lives on <main> so the footer below keeps
     its normal light treatment.

     mr-landing.js still drives:
       - cover src per tile (from the internal #mr-N tag)
       - filter pill single-select behavior + view-transition crossfade
       - "All Episodes" count
     None of those changed in this redesign; only the surrounding
     markup + CSS did. --}}

<main id="main" class="mr-landing">

  {{!-- Close (X) button, top-right. JS un-hides it only when there's
       a same-site referrer (typically: visitor came from an episode
       reader's index button and may want to return). Stays hidden on
       cold loads / direct links / off-site referrers so it doesn't
       suggest a back action that would take them off-site. --}}
  <button class="mr-landing-close" id="mrLandingClose" aria-label="Back to previous page" hidden>
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M3 3L25 25M25 3L3 25" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>

  {{!-- Header: wall-to-wall hero image with title block overlaid
       on the left. Text comes first in DOM order for screen-reader
       sanity; CSS positions image as a full-bleed background and
       title absolutely on top. Image is purely decorative (alt="",
       aria-hidden on the wrapper). --}}
  <header class="mr-landing-header">
    {{!-- Wordmark sits at the top-left of the header, NOT inside
         .mr-landing-header-text — that container is vertically
         centered (justify-content: center) so an inline wordmark
         would also center, pushing it down. Positioning the wordmark
         as a direct child of .mr-landing-header lets CSS anchor it
         absolutely at top-left, matching the position on every other
         page's header. --}}
    {{> "site-wordmark"}}
    <div class="mr-landing-header-text">
      <h1 class="mr-landing-title">Midnight<br>Radio</h1>
      <p class="mr-landing-tagline">Notes on surviving the 21st century and a mixtape delivered &rsquo;round midnight on the 1st and 15th of the month.</p>
    </div>
    <div class="mr-landing-header-image" aria-hidden="true">
      <img src="/assets/mr/mr-header.webp" alt="" loading="eager" />
    </div>
  </header>

  {{!-- Filter row. mr-landing.js single-selects against post tags.
       The All Episodes button's count is populated client-side from
       the rendered tile count. --}}
  <nav class="mr-filters" id="mrFilters" aria-label="Filter episodes by mood">
    <button class="mr-filter is-active" data-filter="" id="mrFilterAll">
      <span id="mrFilterCount">All</span>&nbsp;Episodes
    </button>
    <button class="mr-filter" data-filter="ambient">Ambient</button>
    <button class="mr-filter" data-filter="slow-motion">Slow-Motion</button>
    <button class="mr-filter" data-filter="spirituals">Spirituals</button>
    <button class="mr-filter" data-filter="special-guest">Special Guest</button>
    <button class="mr-filter" data-filter="running">Running</button>
    <button class="mr-filter" data-filter="death-prom">Death Prom</button>
  </nav>

  {{#get "posts" filter="tag:midnight-radio" limit="all" order="published_at desc" include="tags"}}
  <ol class="mr-landing-grid" id="mrLandingGrid">
    {{#foreach posts}}
    <li class="mr-landing-tile" data-slug="{{slug}}" data-tags="{{#foreach tags}}{{slug}} {{/foreach}}">
      <a href="{{url}}" class="mr-landing-tile-link">

        {{!-- Front side: just the cover artwork. Episode number +
             title text are kept in the DOM but visually hidden — the
             cover artwork itself carries the title typographically,
             so a screen overlay would be redundant. Screen readers,
             search engines, and the hidden-tag resolver all still
             see the labels. --}}
        <div class="mr-landing-tile-front">
          <img class="mr-landing-tile-cover" alt="" loading="lazy">
          <span class="mr-landing-tile-eptags" hidden>
            {{#foreach tags visibility="internal"}}<span data-ep="{{slug}}"></span>{{/foreach}}
          </span>
          <p class="mr-landing-tile-num sr-only">
            Midnight Radio
            {{#foreach tags visibility="internal"}}<span class="episode-number" data-ep="{{slug}}"></span>{{/foreach}}
          </p>
          <h3 class="mr-landing-tile-title sr-only">{{title}}</h3>
        </div>

        {{!-- Back side: solid black with the excerpt. Crossfaded in on
             hover via opacity transition. Skipped entirely when the
             post has no custom_excerpt so we don't render a blank
             panel that'd just black-screen on hover. --}}
        {{#if custom_excerpt}}
        <div class="mr-landing-tile-back">
          <p class="mr-landing-tile-excerpt">{{custom_excerpt}}</p>
        </div>
        {{/if}}

      </a>
    </li>
    {{/foreach}}
  </ol>
  {{/get}}

</main>

<script src="{{asset "js/mr-landing.js"}}"></script>
