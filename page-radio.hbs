{{!< default}}

{{!-- /radio/ — Midnight Radio landing.

     Quiet header (title + tagline) → filter row → dense 3-column grid of
     all episodes, newest first. Tiles flow left-to-right per row (natural
     reading order). Every cover image, every title, every description is
     pulled from Ghost dynamically — no per-episode hand-coding. Adding a
     new MR post in Ghost (with the right tags) lands here automatically.

     For each tile, mr-landing.js:
       - reads the internal #mr-N tag and sets the cover src to
         /assets/mr/index/MRI{NN}.webp
       - populates the "All Episodes" count button
       - handles single-select filtering against post.tags

     Filters: single-select. Click a pill → show only matching. Click
     the active pill again, or click "All Episodes", to clear. --}}

<main id="main" class="mr-landing">

  {{!-- Close (←) button in the top-right. Only shown when the visitor
       arrived from another page on this site (e.g. an episode reader's
       index button) — clicking returns them to that page via history.
       Hidden on cold loads / direct links / off-site referrers so it
       doesn't suggest a back action that would take them off-site. --}}
  <button class="mr-landing-close" id="mrLandingClose" aria-label="Back to previous page" hidden>
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

  <header class="mr-landing-header">
    <h1 class="mr-landing-title">Midnight Radio</h1>
    <p class="mr-landing-tagline">Notes on surviving the 21st century and a mixtape delivered &rsquo;round midnight on the 1st and 15th of the month.</p>
  </header>

  <nav class="mr-filters" id="mrFilters" aria-label="Filter episodes by mood">
    <button class="mr-filter is-active" data-filter="" id="mrFilterAll">
      <span id="mrFilterCount">All</span>&nbsp;Episodes
    </button>
    <span class="mr-filter-sep" aria-hidden="true">|</span>
    <button class="mr-filter" data-filter="slow-motion">Slow-Motion</button>
    <span class="mr-filter-sep" aria-hidden="true">|</span>
    <button class="mr-filter" data-filter="spirituals">Spirituals</button>
    <span class="mr-filter-sep" aria-hidden="true">|</span>
    <button class="mr-filter" data-filter="special-guest">Special Guest</button>
    <span class="mr-filter-sep" aria-hidden="true">|</span>
    <button class="mr-filter" data-filter="running">Running</button>
    <span class="mr-filter-sep" aria-hidden="true">|</span>
    <button class="mr-filter" data-filter="death-prom">Death Prom</button>
  </nav>

  {{#get "posts" filter="tag:midnight-radio" limit="all" order="published_at desc" include="tags"}}
  <ol class="mr-landing-grid" id="mrLandingGrid">
    {{#foreach posts}}
    <li class="mr-landing-tile" data-slug="{{slug}}" data-tags="{{#foreach tags}}{{slug}} {{/foreach}}">
      <a href="{{url}}" class="mr-landing-tile-link">
        <div class="mr-landing-tile-image">
          <img class="mr-landing-tile-cover" alt="" loading="lazy">
          <span class="mr-landing-tile-eptags" hidden>
            {{#foreach tags visibility="internal"}}<span data-ep="{{slug}}"></span>{{/foreach}}
          </span>
        </div>
        <div class="mr-landing-tile-body">
          <span class="mr-landing-tile-num">
            {{#foreach tags visibility="internal"}}<span class="episode-number" data-ep="{{slug}}"></span>{{/foreach}}
          </span>
          <h3 class="mr-landing-tile-title">{{title}}</h3>
          {{#if custom_excerpt}}
            <p class="mr-landing-tile-excerpt">{{custom_excerpt}}</p>
          {{/if}}
        </div>
      </a>
    </li>
    {{/foreach}}
  </ol>
  {{/get}}

</main>

<script src="{{asset "js/mr-landing.js"}}"></script>
