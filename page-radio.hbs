<script>
(function() {

    /* ── Filter pills ── */
    const pills  = document.querySelectorAll('.mr-filter-pill');
    const cards  = document.querySelectorAll('.mr-card');
    const activeTags = new Set();

    pills.forEach(pill => {
        pill.addEventListener('click', () => {
            const tag = pill.dataset.tag;
            const isActive = activeTags.has(tag);
            activeTags.clear();
            pills.forEach(p => p.classList.remove('active'));
            if (!isActive) {
                activeTags.add(tag);
                pill.classList.add('active');
            }
            filterCards();
        });
    });

    function filterCards() {
        strip.scrollTo({ left: 0, behavior: 'smooth' });
        cards.forEach(card => {
            const matches = activeTags.size === 0 ||
                (card.dataset.tags || '').split(' ').some(t => activeTags.has(t));

            if (matches && card.hidden) {
                // Reveal: unhide then fade in
                card.hidden = false;
                card.style.opacity = '0';
                card.style.transform = 'scale(0.97)';
                requestAnimationFrame(() => requestAnimationFrame(() => {
                    card.style.opacity = '';
                    card.style.transform = '';
                }));
            } else if (!matches && !card.hidden) {
                // Hide: fade out then collapse
                card.style.opacity = '0';
                card.style.transform = 'scale(0.97)';
                setTimeout(() => { card.hidden = true; card.style.opacity = ''; card.style.transform = ''; }, 250);
            }
        });
        setTimeout(updateThumb, 260);
    }

    /* ── Scrollbar ── */
    const strip = document.getElementById('mrStrip');
    const thumb = document.getElementById('mrStripThumb');
    const track = document.getElementById('mrStripTrack');

    function updateThumb() {
        const scrollW = strip.scrollWidth - strip.clientWidth;
        if (scrollW <= 0) { track.style.display = 'none'; return; }
        track.style.display = 'block';
        const ratio = strip.clientWidth / strip.scrollWidth;
        const thumbW = Math.max(track.offsetWidth * ratio, 30);
        const thumbX = (strip.scrollLeft / scrollW) * (track.offsetWidth - thumbW);
        thumb.style.width  = thumbW + 'px';
        thumb.style.left   = thumbX + 'px';
    }

    strip.addEventListener('scroll', updateThumb, { passive: true });
    window.addEventListener('resize', updateThumb);
    updateThumb();

    /* Horizontal swipe only — vertical scroll passes through to the page. */
    strip.addEventListener('wheel', e => {
        if (Math.abs(e.deltaX) <= Math.abs(e.deltaY)) return;
        e.preventDefault();
        strip.scrollLeft += e.deltaX * 0.4;
    }, { passive: false });

    /* Drag scrollbar thumb */
    let isDragging = false, startX, startLeft;
    thumb.addEventListener('mousedown', e => {
        isDragging = true;
        startX = e.clientX;
        startLeft = strip.scrollLeft;
        e.preventDefault();
    });
    document.addEventListener('mousemove', e => {
        if (!isDragging) return;
        const dx = e.clientX - startX;
        const scrollW = strip.scrollWidth - strip.clientWidth;
        const trackW  = track.offsetWidth - thumb.offsetWidth;
        strip.scrollLeft = startLeft + (dx / trackW) * scrollW;
    });
    document.addEventListener('mouseup', () => { isDragging = false; });

    /* Click on track to jump */
    track.addEventListener('click', e => {
        if (e.target === thumb) return;
        const rect = track.getBoundingClientRect();
        const ratio = (e.clientX - rect.left) / rect.width;
        strip.scrollLeft = ratio * (strip.scrollWidth - strip.clientWidth);
    });

    /* Drag-scroll the strip itself */
    let isStripDragging = false, stripStartX, stripScrollLeft;
    strip.addEventListener('mousedown', e => {
        isStripDragging = true;
        stripStartX = e.pageX - strip.offsetLeft;
        stripScrollLeft = strip.scrollLeft;
        strip.style.cursor = 'grabbing';
    });
    document.addEventListener('mouseup', () => {
        isStripDragging = false;
        strip.style.cursor = 'grab';
    });
    strip.addEventListener('mousemove', e => {
        if (!isStripDragging) return;
        e.preventDefault();
        const x = e.pageX - strip.offsetLeft;
        strip.scrollLeft = stripScrollLeft - (x - stripStartX);
    });

})();
</script>
