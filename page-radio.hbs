{{!< default}}

<script>
document.body.classList.add('has-hero');
</script>

<style>

/* ── Hero ── */
.page-radio .radio-hero-wrapper {
    aspect-ratio: 30/17;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
}

.page-radio .radio-hero-container {
    margin-bottom: 60px;
}

/* ── Two-column overlay grid inside the hero — bottom-aligned ── */
.mr-hero-overlay {
    position: absolute;
    bottom: 40px;
    left: 50%;
    /* translateZ(0) forces a permanent GPU compositing layer in Safari,
       preventing text from disappearing when backdrop-filter on the player
       triggers a repaint of the parent stacking context on hover */
    transform: translateX(-50%) translateZ(0);
    width: 90%;
    max-width: 1250px;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: 12%;
    align-items: end;
}

/* Disable scale/brightness effect on the radio page hero only */
.page-radio .radio-hero-wrapper:hover .image-slider img {
    transform: none;
    filter: none;
    transition: none;
}

/* style.css has .radio-hero-wrapper:hover svg { transform: translateX(6px) }
   Override for ALL SVGs in the overlay (player icons + signup loading spinner) */
.page-radio .radio-hero-wrapper:hover .mr-hero-overlay svg {
    transform: translateX(0) !important;
    transition: none !important;
}

/* Col 1: title + tagline + signup */
.mr-hero-col1 {
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 560px;
}

.mr-hero-col1 h1 {
    color: #fff;
    margin-top: 0;
    margin-bottom: 24px;
    width: 100%;
}

/* Tagline — Figma: bebas-neue-pro-semiexpanded, 36px, lh 1.05, ls 0.36px */
/* [data-theme] prefix to beat [data-theme="light"] p specificity */
[data-theme] .mr-tagline,
.mr-tagline {
    font-family: var(--font-big-alt, 'bebas-neue-pro-semiexpanded', sans-serif);
    font-size: 36px;
    line-height: 1.05;
    letter-spacing: 0.36px;
    font-weight: bold;
    color: #fff;
    margin-top: 0;
    margin-bottom: 30px;
}

/* Col 2: player, right-aligned */
.mr-hero-col2 {
    display: flex;
    justify-content: flex-end;
    align-items: center;
}

.mr-hero-col2 .mr-player {
    margin: 0;
    width: 100%;
    max-width: 450px;
}

.mr-member-note {
    font-style: italic;
    font-size: 15px;
    color: rgba(255,255,255,0.6);
    margin-top: 0;
}

/* Subscribe button — pill style, white bg / black text.
   Uses #main in selector to beat Ghost's #main .kg-signup-card-button { font-size: 16px !important } */
#main .mr-hero-col1 .kg-signup-card-button {
    font-family: var(--font-big-alt, 'bebas-neue-pro-semiexpanded', sans-serif) !important;
    font-size: 19px !important;
    border-radius: 5px !important;
    padding: 10px 20px !important;
    background: #ffffff !important;
    color: #000000 !important;
    text-transform: uppercase !important;
    line-height: 1 !important;
    transition: background 0.15s ease !important;
    border: none !important;
    cursor: pointer !important;
    align-self: center !important;
    height: auto !important;
    min-height: unset !important;
}
/* Ghost core CSS sets the inner span to white — override it */
#main .mr-hero-col1 .kg-signup-card-button .kg-signup-card-button-default {
    color: #000000 !important;
    font-size: 19px !important;
}
#main .mr-hero-col1 .kg-signup-card-button:hover {
    background: #e0e0e0 !important;
}
#main .mr-hero-col1 .kg-signup-card-button:hover .kg-signup-card-button-default {
    color: #000000 !important;
}


/* ── Strip outer ── */

.mr-strip-outer {
    position: relative;
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
    overflow: hidden;
    margin-top: 80px;
}

.mr-strip {
    display: flex;
    gap: 24px;
    overflow-x: scroll;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: 0 5% 30px 12%;
    cursor: grab;
    align-items: stretch;
}

.mr-strip::-webkit-scrollbar { display: none; }
.mr-strip:active { cursor: grabbing; }

/* ── Cards ── */

.mr-card {
    flex-shrink: 0;
    width: 450px;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0px 4px 4px 0px rgba(0,0,0,0.15);
    display: flex;
    flex-direction: column;
    transition: opacity 0.25s ease, transform 0.25s ease;
}

/* ── Episode card colors (auto-extracted, tune manually) ── */
.mr-color-43 { --card-bg: linear-gradient(180deg, #502816 0%, #2E1408 100%); }
.mr-color-42 { --card-bg: linear-gradient(180deg, #252525 0%, #111 100%); }
.mr-color-41 { --card-bg: linear-gradient(180deg, #133816 0%, #102511 100%); }
.mr-color-40 { --card-bg: hsl(0,0%,10%); }
.mr-color-39 { --card-bg: hsl(60,33%,15%); }
.mr-color-38 { --card-bg: hsl(30,50%,20%); }
.mr-color-37 { --card-bg: hsl(0, 0%, 36%); }
.mr-color-36 { --card-bg: hsl(180,33%,15%); }
.mr-color-35 { --card-bg: hsl(0,50%,20%); }
.mr-color-34 { --card-bg: hsl(30,33%,29%); }
.mr-color-33 { --card-bg: hsl(60,33%,15%); }
.mr-color-32 { --card-bg: hsl(0,0%,10%); }
.mr-color-31 { --card-bg: linear-gradient(180deg, #20453A 0%, #18342C 100%); }
.mr-color-30 { --card-bg: hsl(60,33%,15%); }
.mr-color-29 { --card-bg: hsl(60,33%,15%); }
.mr-color-28 { --card-bg: hsl(0,100%,15%); }
.mr-color-27 { --card-bg: hsl(220,60%,25%); }
.mr-color-26 { --card-bg: hsl(0,50%,20%); }
.mr-color-25 { --card-bg: hsl(0,33%,29%); }
.mr-color-24 { --card-bg: hsl(30,50%,20%); }
.mr-color-23 { --card-bg: hsl(198, 32%, 29%); }
.mr-color-22 { --card-bg: hsl(60,33%,15%); }
.mr-color-21 { --card-bg: hsl(210,100%,20%); }
.mr-color-20 { --card-bg: hsl(0,20%,25%); }
.mr-color-19 { --card-bg: hsl(60,33%,15%); }
.mr-color-18 { --card-bg: hsl(30,33%,29%); }
.mr-color-17 { --card-bg: hsl(0,100%,20%); }
.mr-color-16 { --card-bg: hsl(0,19%,40%); }
.mr-color-15 { --card-bg: hsl(60,100%,15%); }
.mr-color-14 { --card-bg: hsl(20,100%,15%); }
.mr-color-13 { --card-bg: hsl(60,33%,15%); }
.mr-color-12 { --card-bg: hsl(300,33%,15%); }
.mr-color-11 { --card-bg: hsl(0,0%,10%); }
.mr-color-10 { --card-bg: hsl(30,33%,29%); }
.mr-color-9  { --card-bg: hsl(30,33%,29%); }
.mr-color-8  { --card-bg: hsl(60,33%,15%); }
.mr-color-7  { --card-bg: hsl(30,50%,20%); }
.mr-color-6  { --card-bg: hsl(30,100%,20%); }
.mr-color-5  { --card-bg: hsl(20,60%,25%); }
.mr-color-4  { --card-bg: hsl(90,50%,20%); }
.mr-color-3  { --card-bg: hsl(180,33%,15%); }
.mr-color-2  { --card-bg: hsl(30,50%,20%); }
.mr-color-1  { --card-bg: hsl(60,33%,15%); }

.mr-card[hidden] { display: none !important; }

.mr-card-link {
    display: flex;
    flex-direction: column;
    flex: 1;
    text-decoration: none;
    background-image: none !important;
    padding-bottom: 0;
}

.mr-card-link:hover {
    background-image: none !important;
}

/* Card image */

.mr-card-image {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
}

.mr-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 3s ease;
}

.mr-card-link:hover .mr-card-image img {
    transform: scale(1.02);
}

/* Overlay: darkens top-left for text readability */

.mr-card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 25px;
    background: linear-gradient(156.6deg, rgb(0,0,0) 16.943%, rgba(0,0,0,0) 45.774%);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    /* Safari: prevent overlay from being dropped when the sibling img
       gets promoted to a GPU compositing layer during transform: scale() */
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
}

/* Episode number label */

.mr-card-overlay h5 {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.35;
    margin: 0 0 10px;
    font-weight: 600;
}

/* Episode title */

.mr-card-overlay h2 {
    font-family: var(--font-big);
    font-size: 75px;
    padding-right: 15%;
    line-height: .8;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
}

/* Card body */

.mr-card-body {
    padding: 15px 25px 20px 25px;
    flex: 1;
    background: var(--card-bg, #222222);
}


.mr-card-body p {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.44;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 14px;
    font-weight: 400;
}


.mr-card-body ol {
    margin: 0;
    list-style-type: decimal;
    padding: 0 0 0 .75em;
}

.mr-card-body ol li {
font-family: var(--font-sans);
    font-size: 12px;
    line-height: 1.3;
    letter-spacing: 0.14px;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 5px;
    padding-bottom: 0
}

.mr-card-body ol li:last-child {
    margin-bottom: 0;
}

.mr-card-body ol li::marker {
    font-size: 75%;
}

/* ── Scrollbar indicator ── */

.mr-strip-scrollbar {
    position: relative;
    height: 4px;
    background: rgba(255, 255, 255, 0.08);
    max-width: var(--max-w);
    margin: 10px auto 10px;
    border-radius: 6px;
    cursor: pointer;
}

[data-theme="light"] .mr-strip-scrollbar {
    background: rgba(0, 0, 0, 0.08);
}

.mr-strip-scrollbar-thumb {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: 13px;
    background: #908f8c;
    border-radius: 6px;
    cursor: grab;
}

[data-theme="light"] .mr-strip-scrollbar-thumb {
    background: #000000;
}

.mr-strip-scrollbar-thumb:active { cursor: grabbing; }

/* ── Filter pills (below strip) ── */

.mr-filters {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 30px;
    margin-bottom: 80px;
}

.mr-filter-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    border-radius: 5px;
    border: none;
    font-family: var(--font-big-alt);
    font-size: 19px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    background: #222222;
    color: #ffffff;
    cursor: pointer;
    transition: background 0.15s ease;
    line-height: 1;
}

[data-theme="light"] .mr-filter-pill {
    background: #ffffff;
    color: #000000;
    border: 1px solid #d8d8d8;
}

.mr-filter-pill:hover,
.mr-filter-pill.active {
    background: #444444;
}

[data-theme="light"] .mr-filter-pill:hover,
[data-theme="light"] .mr-filter-pill.active {
    background: #000000;
    color: #ffffff;
    border-color: #000000;
}


/* ── Responsive ── */

@media (max-width: 1024px) {
    .mr-card { width: 380px; }
    .mr-card-overlay h2 { font-size: 52px; line-height: 48px; }
}

@media (max-width: 700px) {
    .mr-filters { padding-left: 5%; margin-bottom: 50px; }
    .mr-strip { padding-left: 5%; }
    .mr-card { width: 250px; }
    .mr-card-overlay { padding: 15px; }
    .mr-card-overlay h5 { font-size: 9px; letter-spacing: 1px; margin-bottom: 5px;}
    .mr-card-overlay h2 { font-size: 36px; line-height: 32px; }
    .mr-card-body { padding: 10px 10px 15px 15px; }
    .mr-card-body p { font-size: 13px; }
    .mr-strip-scrollbar { max-width: 90%; }
    .mr-filter-pill { font-size: 16px; height: 44px; padding: 0 20px; }
}

</style>


<main id="main" class="content outer radio-page">
    {{#post}}

    <div class="radio-hero-container">
        <div class="radio-hero-wrapper">
            <div class="image-slider">
                <img src="{{asset "/img/midnight.webp" }}" alt="Saint Jerome in His Study by Caravaggio"/>
            </div>

            <div class="mr-hero-overlay">
                <div class="mr-hero-col1">
                    <h1>Midnight<br>Radio</h1>
                    <p class="mr-tagline">Notes on surviving the 21st century and a mixtape delivered 'round midnight on the 1st and 15th of the month.</p>
                    {{#if @member}}<p class="mr-member-note">Thank you for being a rare and wonderful Midnight Radio Member.</p>
                    {{else}}{{> "signup"}}
                    {{/if}}
                </div>
                <div class="mr-hero-col2">
                    {{> "midnight-radio-player"}}
                </div>
            </div>
        </div>
    </div>


    <div class="radio-content-wrapper">

        <!-- Episode strip -->
        <div class="mr-strip-outer">
            <div class="mr-strip" id="mrStrip">

                <!-- MR 43 -->
                <div class="mr-card" data-tags="1990s">
                    <a href="/neglected-utopian-energy" class="mr-card-link">
                        <div class="mr-card-image">
                            <img src="{{asset "/mr/MRI43.webp"}}" alt="Neglected Utopian Energy">
                            <div class="mr-card-overlay">
                                <h5>Midnight Radio 43</h5>
                                <h2>Neglected Utopian Energy</h2>
                            </div>
                        </div>
                        <div class="mr-card-body mr-color-43">
                            <p>Sink into this plush couch while <em>Strange Days</em> plays on mute and somebody talks about the Information Superhighway.</p>
                            <ol>
                                <li>Dr. Atmos & Oliver Lieb - Music to Films Movement V</li>
                                <li>Pete Namlook & Richie Hawtin - Silent Intelligence V</li>
                                <li>Bedouin Ascent - Mammon</li>
                                <li>Massive Attack vs. Mad Professor - Protection</li>
                                <li>B12 - Radiophonic Workshop</li>
                            </ol>                        
                        </div>
                    </a>
                </div>

                <!-- MR 42 -->
                <div class="mr-card" data-tags="special-guest spirituals">
                    <a href="/return-of-the-gods" class="mr-card-link">
                        <div class="mr-card-image">
                            <img src="{{asset "/mr/MRI42.webp"}}" alt="Return of the Gods">
                            <div class="mr-card-overlay">
                                <h5>Midnight Radio 42 · Martin Essig Edition</h5>
                                <h2>Return of the Gods</h2>
                            </div>
                        </div>
                        <div class="mr-card-body mr-color-42">
                            <p>Ruminations on being enchanted, disenchanted, and hopefully back again—featuring a very special theological meditation.</p>
                            <ol>
                                <li>XDCVR - Psalm 68</li>
                                <li>Luke Slater - Love (Burial Remix)</li>
                                <li>Sun Electric - Episode VI</li>
                                <li>Blawan - 993</li>
                                <li>Jürgen Paape - So Weit Wie Noch Nie</li>
                            </ol>                        </div>
                    </a>
                </div>

                <!-- MR 41 -->
                <div class="mr-card" data-tags="1990s running">
                    <a href="/conversations-with-the-drum" class="mr-card-link">
                        <div class="mr-card-image">
                            <img src="{{asset "/mr/MRI41.webp"}}" alt="Conversations With the Drum">
                            <div class="mr-card-overlay">
                                <h5>Midnight Radio 41</h5>
                                <h2>Conversations With the Drum</h2>
                            </div>
                        </div>
                        <div class="mr-card-body mr-color-41">
                            <p>A dedication to the Richie Hawtin's Concept records where an offset snare becomes high drama.</p>
                            <ol>
                                <li>96:01 01:00</li>
                                <li>96:01 02:00 VR</li>
                                <li>96:05 09:00</li>
                                <li>96:05 10:00</li>
                                <li>96:07 13:00</li>
                            </ol>                        </div>
                    </a>
                </div>

                <!-- MR 40 -->
                <div class="mr-card" data-tags="special-guest slow-motion">
                    <a href="/bodies-without-organs" class="mr-card-link">
                        <div class="mr-card-image">
                            <img src="{{asset "/mr/MRI40.webp"}}" alt="Bodies Without Organs">
                            <div class="mr-card-overlay">
                                <h5>Midnight Radio 40 · Candy Chang Edition</h5>
                                <h2>Bodies Without Organs</h2>
                            </div>
                        </div>
                        <div class="mr-card-body mr-color-40">
                            <p>Inspirational music and a pair of slow-motion bangers from '82 in an episode about art and death.</p>
                            <ol>
                                <li>Bertrand Belin - Choses Nouvelles</li>
                                <li>Füxa - Dirty D</li>
                                <li>Damien Jurado & Richard Swift - Radioactivity</li>
                                <li>Cliff Martinez - Abscess</li>
                                <li>The Cure - Plainsong</li>
                            </ol>                        </div>
                    </a>
                </div>

                <!-- MR 39 -->
                <div class="mr-card" data-tags="slow-motion ambient">
                    <a href="/night-flight-to-vienna" class="mr-card-link">
                        <div class="mr-card-image">
                            <img src="{{asset "/mr/MRI39.webp"}}" alt="Night Flight to Vienna">
                            <div class="mr-card-overlay">
                                <h5>Midnight Radio 39</h5>
                                <h2>Night Flight to Vienna</h2>
                            </div>
                        </div>
                        <div class="mr-card-body mr-color-39">
                            <p>Slow grain pulse and dub that strips the world down to studs while we practice the lectio divina with a deep winter chug.</p>
                            <ol>
                                <li>F.U.S.E. - Night Drive</li>
                                <li>My Friend Earl - Snowblow</li>
                                <li>Monolake - Cyan (44% slower)</li>
                                <li>Tropic of Cancer - Dive</li>
                                <li>The Field - Leave It (31% slower)</li>
                            </ol>                        </div>
                    </a>
                </div>

                <!-- MR 38 -->
                <div class="mr-card" data-tags="special-guest">
                    <a href="/darkly-euphoric" class="mr-card-link">
                        <div class="mr-card-image">
                            <img src="{{asset "/mr/MRI38.webp"}}" alt="Darkly Euphoric">
                            <div class="mr-card-overlay">
                                <h5>Midnight Radio 38 · Burnlab Edition</h5>
                                <h2>Darkly Euphoric</h2>
                            </div>
                        </div>
                        <div class="mr-card-body mr-color-38">
                            <p>Glittery future-shock goth-punk for these days of intense digital pleasure that masks a psychosocial collapse.</p>
                            <ol>
                                <li>Liars - No. 1 Against the Rush</li>
                                <li>Cold Cave - Double Lives in Single Beds</li>
                                <li>Telefon Tel Aviv - You are the Worst Thing in the World</li>
                                <li>The Horrors - Sea Within a Sea</li>
                                <li>Adult. - Tonight We Fall</li>
                            </ol>                        
                        </div>
                    </a>
                </div>

                <!-- MR 37 -->
                <div class="mr-card" data-tags="ambient spirituals">
                    <a href="/first-things" class="mr-card-link">
                        <div class="mr-card-image">
                            <img src="{{asset "/mr/MRI37.webp"}}" alt="First Things">
                            <div class="mr-card-overlay">
                                <h5>Midnight Radio 37</h5>
                                <h2>First Things</h2>
                            </div>
                        </div>
                        <div class="mr-card-body mr-color-37">
                            <p>hurchy drone and astronaut music with the serene energy I fantasize about cultivating in the first minutes of a new year.</p>
                            <ol>
                                <li>Kali Malone - Spectacle of Ritual</li>
                                <li>Abul Mogard - Desires Are Reminiscences By Now</li>
                                <li>Autechre - VLetrmx21 (65% slower)</li>
                            </ol>                        
                        </div>
                    </a>
                </div>

                <!-- MR 36 -->
                <div class="mr-card" data-tags="spirituals">
                    <a href="/holiday-lullaby" class="mr-card-link">
                        <div class="mr-card-image">
                            <img src="{{asset "/mr/MRI36.webp"}}" alt="Holiday Lullaby">
                            <div class="mr-card-overlay">
                                <h5>Midnight Radio 36</h5>
                                <h2>Holiday Lullaby</h2>
                            </div>
                        </div>
                        <div class="mr-card-body mr-color-36">
                            <p>Vocal workouts and hopeful classics with notes on robot spouses and the future of friction.</p>
                            <ol>
                                <li>Julianna Barwick - Prizewinning</li>
                                <li>Matchess - Bellum Omnium Contra Omnes</li>
                                <li>Vril - Infinitum Eternis Anime</li>
                                <li>Rhos Male Voice Choir - Psalm 23</li>
                            </ol>                        
                        </div>
                    </a>
                </div>

                <!-- MR 35 -->
                <div class="mr-card" data-tags="slow-motion">
                    <a href="/slow-gold" class="mr-card-link">
                        <div class="mr-card-image">
                            <img src="{{asset "/mr/MRI35.webp"}}" alt="Slow Gold">
                            <div class="mr-card-overlay">
                                <h5>Midnight Radio 35</h5>
                                <h2>Slow Gold</h2>
                            </div>
                        </div>
                        <div class="mr-card-body mr-color-35">
                            <p>Slow motion Breakfast Club anthems served with tornados, egg foo young, and trashed algorithms.</p>
                            <ol>
                                <li>Simple Minds - Don't You Forget About Me (38% slower)</li>
                                <li>Will Web - Spacewalk (30% slower)</li>
                                <li>Swans - Leaving Meaning (20% slower)</li>
                                <li>Pole - Hafen (40% slower)</li>
                                <li>Aphex Twin - #1 (Cliffs) (42% slower)</li>
                            </ol>                        </div>
                    </a>
                </div>

                <!-- MR 34 -->
                <div class="mr-card" data-tags="ambient">
                    <a href="/absorb-the-poison/" class="mr-card-link">
                        <div class="mr-card-image">
                            <img src="{{asset "/mr/MRI34.webp"}}" alt="Absorb the Poison">
                            <div class="mr-card-overlay">
                                <h5>Midnight Radio 34</h5>
                                <h2>Absorb The Poison</h2>
                            </div>
                        </div>
                        <div class="mr-card-body mr-color-34">
                            <p>An ode to Michael Clayton and the giddy illusion of renewal before death.</p>
