{{!< default}}

{{!-- Override the <title> block declared in default.hbs to strip the
     "(Page 1)" suffix Ghost auto-appends to routes.yaml collection
     pages. Single page, no real pagination, no value in the suffix. --}}
{{#contentFor "title"}}Public Works — {{@site.title}}{{/contentFor}}

{{!-- /public-works/ — section index.
     Gallery-dark TOC with a 3-col grid of project tiles. The dark
     background lives on <main> (not <body>) so the footer below keeps
     its normal light treatment. The {{#get}} that surfaces the post
     list is provided by the collection in routes.yaml — `posts` is in
     scope here.

     Tile data:
       - feature_image → tile image
       - title         → tile title (uppercase Bebas)
       - custom_excerpt → tile subtitle (venue • city)

     Author note: set each project's custom_excerpt in Ghost admin to
     something like "Historic GreenWood Chapel • Brooklyn". Falls back
     to no subtitle if blank.

     The X close button is referrer-based (matches the MR landing
     pattern): only shown if the visitor came from another page on
     this site (typically from a project deck via the index icon),
     and goes back via history.back(). For cold loads / search-engine
     referrers the button stays hidden because "back" would take
     them off-site. --}}

<main id="main" class="public-works-index">

  <header class="public-works-index-header">
    <div class="public-works-index-title-stack">
      {{> "site-wordmark"}}
      <h1 class="public-works-index-headline">Public<br>Works</h1>
    </div>
    <button class="public-works-index-close" id="publicWorksClose" aria-label="Back to previous page" hidden>
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 3L25 25M25 3L3 25" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </header>

  <ol class="public-works-grid">
    {{#foreach posts}}
    <li class="public-works-tile">
      <a class="public-works-tile-link" href="{{url}}">
        <div class="public-works-tile-image">
          {{#if feature_image}}
            <img
              srcset="{{img_url feature_image size="s"}} 600w, {{img_url feature_image size="m"}} 800w, {{img_url feature_image size="l"}} 1200w"
              sizes="(max-width: 1024px) 100vw, 33vw"
              src="{{img_url feature_image size="m"}}"
              alt="{{title}}"
              loading="lazy"
            />
          {{/if}}
        </div>
        <div class="public-works-tile-overlay">
          <div class="public-works-tile-text">
          <h2 class="public-works-tile-title">{{title}}</h2>
          {{#if custom_excerpt}}
            <p class="public-works-tile-venue">{{custom_excerpt}}</p>
          {{/if}}
          </div>
        </div>
      </a>
    </li>
    {{/foreach}}
  </ol>

</main>

<script>
  (function setupCloseButton() {
    var btn = document.getElementById('publicWorksClose');
    if (!btn) return;
    var ref = document.referrer;
    var sameOrigin = false;
    try {
      sameOrigin = !!ref && new URL(ref).origin === location.origin;
    } catch (e) { sameOrigin = false; }
    if (!sameOrigin) return;
    btn.hidden = false;
    btn.addEventListener('click', function () { history.back(); });
  })();
</script>
