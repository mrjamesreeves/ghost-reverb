<style>
  :root {
    --color-bg: #111;
    --strip-height: 460px;
    --strip-height-mobile: 260px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }


  /* ── Strip wrapper ── */

  .spite-strip-outer {
    width: 100%;
    overflow: hidden;         /* hides scrollbar chrome */
    position: relative;
    padding-top: 60px;
  }

  .spite-strip {
    display: flex;
    gap: 12px;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;           /* Firefox */
    padding: 0 5% 0 5%;             /* left indent matches your site padding */
    padding-right: calc(5% + 80px); /* extra right so last card isn't hidden by fade */
  }

  .spite-strip::-webkit-scrollbar { display: none; }
  .spite-strip.is-grabbing { cursor: grabbing; }

  /* ── Cards ── */

  .spite-strip-card {
    scroll-snap-align: start;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .spite-strip-image {
    height: var(--strip-height);
    background: #1a1a1a;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Card width is driven by the image's natural aspect ratio */
  .spite-strip-image img {
    height: 100%;
    width: auto;
    display: block;
    border-radius: 12px;
  }

  .spite-strip-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    padding-left: 2px;
    text-align: center;
  }

  /* ── Responsive ── */

  @media (max-width: 700px) {
    :root { --strip-height: 260px; }

    .spite-strip-outer::after {
      width: 50px;
      height: calc(var(--strip-height) + 36px);
    }
  }
</style>

