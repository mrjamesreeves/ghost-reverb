{{!< default}}

<style>

/* ---- Typography overrides ---- */

.kg-image-card img {
    margin-left: 0;
    width: 150px;
    margin-bottom: -50px;
    margin-top: 50px;
    }

#icon {
    margin-bottom: 10px !important;
    }

h1 {
    margin-top: 20px;
    color: var(--color-hover);
    }

h2 {
    color: var(--color-hover);
    margin-top: 80px;
    font-size: 50px;
    }

h3 {
    font-size: 20px;
    letter-spacing: normal;
    text-transform: none;
    font-weight: 700 !important;
    margin-top: 50px;
    }

h4 {
    font-size: var(--type-body);
    letter-spacing: normal;
    text-transform: none;
    font-weight: 700 !important;
    margin-top: 20px;
    color: #fff;
    }

h5 + h2 {
    margin-top: 0px;
    }

h3:first-of-type {
    margin-top: 0;
    }

blockquote {
    padding-left: 0;
    margin-top: 50px;
    border-left: none;
    }

blockquote h1 {
    font-size: 60px;
    line-height: .9;
    color: #222;
    }

blockquote cite {
    color: #333;
    }

.comments-area.inner {
    max-width: 700px;
    }

p {
    margin-top: 5px;
    margin-bottom: 25px;
    font-weight: 400;
    font-family: var(--font-sans);
    }

ul, ol {
    margin-top: 30px;
    margin-left: 10px;
    margin-right: 50px;
    margin-bottom: 30px;
    }

li {
    margin-bottom: 15px;
    line-height: 1.5;
    font-size: var(--type-body);
    font-family: var(--font-sans) !important;
    }

ul li::marker {
    color: #444;
    }

.post-content ol li, .post-content ul li {
    font-family: var(--font-sans);
    padding-bottom: 8px;
    }

li::marker {
    font-size: 13px;
    }

a, a:hover {
    background-image: none;
    }

li a {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 0.5px;
    }

h3 + ol, h3 + ul, h4 + ul {
    margin-top: 25px !important;
    }

p + ul {
    margin-top: -15px !important;
    }

strong {
    color: var(--color-hover);
    }

h6 {
    font-size: 12px;
    font-weight: 500;
    line-height: 1.7;
    padding-left: 20px;
    border-left: 3px solid var(--color-text);
    }

h6 a {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 0.5px;
    font-size: 12px;
    font-weight: 500;
    }

h5.kg-toggle-heading-text {
    font-size: 16px !important;
    text-transform: none !important;
    letter-spacing: normal !important;
    font-weight: 600;
}

.kg-toggle-card-icon svg {
    color: #fff;
    }

[data-theme="dark"] .kg-toggle-card-icon svg {
    color: #000;
}

/* ---- Hide default post header ---- */

.post-header-content {
    text-align: left;
    display: none;
    }

.post-header-content + .post-content > p:first-child {
    display: none;
    }

.footer-tags {
    display: none;
    }

/* ---- Hero ---- */

.spite-hero {
    width: 100%;
    max-width: 1300px;
    margin: 0 auto 40px;
    text-align: center;
    padding: 60px 5% 0;
    box-sizing: border-box;
    }

.spite-hero-header {
    margin-bottom: 50px;
    }

.spite-hero-header h1 {
    font-family: var(--font-big);
    font-size: 7rem;
    letter-spacing: 0.05em;
    margin: 0 0 5px;
    text-transform: uppercase;
    }

.spite-subhead {
    font-size: 1.3rem;
    font-family: var(--font-sans);
    color: var(--color-text);
    margin-top: 0;
    margin-bottom: 30px;
    font-weight: 400;
    }

/* Download buttons (outline style) */

.spite-download-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    }

.spite-download-buttons a {
    display: inline-block;
    padding: 10px 24px;
    border: 1px solid var(--color-text);
    border-radius: 6px;
    font-size: var(--type-body-sm);
    font-weight: 600;
    font-family: var(--font-sans);
    color: var(--color-hover);
    text-decoration: none;
    background-image: none;
    transition: border-color 0.2s ease, background 0.2s ease;
    }

.spite-download-buttons a:hover {
    border-color: var(--color-hover);
    background: rgba(255,255,255,0.05);
    }

[data-theme="light"] .spite-download-buttons a:hover {
    background: rgba(0,0,0,0.05);
    }

/* Screenshot carousel */

.spite-screenshot {
    position: relative;
    width: 100%;
    aspect-ratio: 300 / 135;
    overflow: hidden;
    }

.spite-screenshot img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 1s ease-in-out;
    }

.spite-screenshot img:first-child {
    position: relative;
    opacity: 1;
    }

.spite-screenshot img.active {
    opacity: 1;
    }

/* Price line */

.spite-price {
    text-align: center;
    font-size: var(--type-body-sm);
    color: var(--color-text-muted);
    margin-top: 30px;
    margin-bottom: 0;
    font-family: var(--font-sans);
    }

/* ---- Nav (pill buttons) ---- */

.app-nav {
    display: flex;
    gap: 10px;
    margin-top: 40px;
    margin-bottom: 10px;
    justify-content: center;
    flex-wrap: wrap;
    background: none;
    padding: 0;
    width: 100%;
    }

.app-nav a {
    display: inline-block;
    padding: 8px 20px;
    border: 1px solid var(--color-text-muted);
    border-radius: 30px;
    font-size: var(--type-body-sm);
    font-weight: 600;
    font-family: var(--font-sans);
    color: var(--color-text);
    text-decoration: none;
    background-image: none;
    transition: border-color 0.2s ease, color 0.2s ease;
    }

.app-nav a:hover {
    border-color: var(--color-hover);
    color: var(--color-hover);
    text-decoration: none;
    background-size: 0;
    }

.app-nav a.active {
    border-color: var(--color-hover);
    color: var(--color-hover);
    text-decoration: none;
    }

/* ---- Content (single centered column) ---- */

.spite-content {
    max-width: 650px;
    margin: 0 auto;
    padding-top: 20px;
    }

.spite-credits {
    margin-top: 60px;
    }

/* Bottom download section */

.spite-bottom-download {
    text-align: center;
    margin-top: 60px;
    margin-bottom: 40px;
    }

/* ---- Responsive ---- */

@media (max-width: 700px) {
    .spite-hero {
        padding: 40px 5% 0;
        margin-bottom: 20px;
        }

    .spite-hero-header h1 {
        font-size: 4.5rem;
        }

    .spite-subhead {
        font-size: 1.1rem;
        }

    .spite-download-buttons {
        flex-direction: column;
        align-items: center;
        }

    .spite-download-buttons a {
        width: 220px;
        text-align: center;
        }

    .spite-screenshot {
        aspect-ratio: auto;
        height: auto;
        }

    .spite-screenshot img {
        position: relative !important;
        }

    .app-nav {
        gap: 8px;
        }

    .app-nav a {
        font-size: 13px;
        padding: 7px 16px;
        }

    ul, ol {
        margin-left: 0;
        margin-right: 0;
        margin-top: 0;
        margin-bottom: 20px;
        }

    p, ul li, ol li { font-size: 14px; }

    p { margin-bottom: 10px; }

    h2 { font-size: 36px; margin-top: 50px; }

    blockquote h1 { font-size: 30px; }
    blockquote { padding-left: 0; border-left: none; }

    .radio-page .radio-content-wrapper {
        padding-left: 5%;
        padding-right: 5%;
        }
}

</style>

<main id="main" class="content outer radio-page">

    {{#post}}

    <!-- Hero: title, subhead, buttons, screenshots -->
    <div class="spite-hero">
        <div class="spite-hero-header">
            <h1>Spite</h1>
            <p class="spite-subhead">A dignified music player.</p>
            <div class="spite-download-buttons">
                <a href="https://apps.apple.com/us/app/spite-music-player/id6757397964">Download for Mac</a>
                <a href="https://apps.apple.com/us/app/spite-music-player/id6757397964">Download for iPhone</a>
            </div>
        </div>

        <div class="spite-screenshot">
            <img src="{{asset "spite/spite1.webp"}}" alt="Spite" class="active">
            <img src="{{asset "spite/spite2.webp"}}" alt="Spite">
            <img src="{{asset "spite/spite3.webp"}}" alt="Spite">
            <img src="{{asset "spite/spite4.webp"}}" alt="Spite">
            <img src="{{asset "spite/spite5.webp"}}" alt="Spite">
        </div>

        <p class="spite-price">$10 after a 30-day trial</p>
    </div>

    <div class="radio-content-wrapper">
        <!-- Pill navigation -->
        <nav class="app-nav">
            <a href="/spite/" data-slug="spite">Features</a>
            <a href="/spite-test-center/" data-slug="spite-test-center">Updates + Support</a>
            <a href="/spite-terms-privacy/" data-slug="spite-terms-privacy">Terms + Privacy</a>
            <a href="https://apps.apple.com/us/app/spite-music-player/id6757397964">Download</a>
        </nav>
        <script>
        // Highlight active nav item
        (function() {
            const currentSlug = '{{slug}}';
            const links = document.querySelectorAll('.app-nav a[data-slug]');
            links.forEach(link => {
                if (link.getAttribute('data-slug') === currentSlug) {
                    link.classList.add('active');
                }
            });
        })();
        </script>

        <div class="inner-wide">
            <div class="spite-content">
                {{content}}

                {{#has slug="spite-test-center"}}
                    {{> comments}}
                {{/has}}

                {{#has slug="spite"}}
                    <div class="spite-bottom-download">
                        <div class="spite-download-buttons">
                            <a href="https://apps.apple.com/us/app/spite-music-player/id6757397964">Download for Mac</a>
                            <a href="https://apps.apple.com/us/app/spite-music-player/id6757397964">Download for iPhone</a>
                        </div>
                    </div>
                {{/has}}

                {{#has slug="spite-test-center"}}
                {{else}}
                    {{#has slug="spite"}}
                    {{else}}
                        <div class="spite-credits">
                            <h6>Heavy duty thanks to <a href="http://candychang.com">Candy Chang</a>, <a href="https://timbornholdt.com">Tim Bornholdt</a>, <a href="https://www.thetonearm.com">Michael Donaldson</a>, <a href="http://oliverfarshi.com">Oliver Farshi</a>, <a href="https://hicks.design">Jon Hicks</a>, <a href="http://davidmead.com">David Mead</a>, <a href="https://danparham.com">Dan Parham</a>, and <a href="http://ruk.ca">Peter Rukavina</a></h6>
                        </div>
                    {{/has}}
                {{/has}}
            </div>
        </div>
    </div>


<!-- EPISODES -->
    <div class="inner-wide">
        <div class="grid grid-more">
            {{#get "posts" include="authors,tags,tiers" filter="tag:midnight-radio+id:-{{id}}" limit="3"}}
            {{#foreach posts visibility="all"}}
                <article>
                    <a href="{{url}}" class="post-card-link">
                    <div class="post-card bg-dark bg-full">

                        {{#if feature_image}}
                            <img
                                class="post-card-image bg-full-image bg-fade-in"
                                srcset="{{img_url feature_image size="xs"}} 300w, {{img_url feature_image size="s" }} 600w, {{img_url feature_image size="m" }} 800w, {{img_url feature_image size="l" }} 1200w, {{img_url feature_image size="xl" }} 1600w, {{img_url feature_image size="xxl" }} 2000w"
                                sizes="(min-width: 1600px) 1600px, 100vw"
                                src="{{img_url feature_image size="xl"}}"
                                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                            />
                        {{/if}}

                        <div class="post-card-inside">
                            <div class="post-card-content">
                                <div class="big-title">
                                    <h5>
                                        Midnight Radio
                                        {{#foreach tags visibility="internal"}}
                                        {{#if (match slug "^hash-mr-")}}
                                            <span class="episode-number" data-ep="{{slug}}"></span>
                                        {{/if}}
                                        {{/foreach}}
                                    </h5>
                                    <h2>{{title}}</h2>
                                </div>
                            </div>
                        </div>
                    </div>
                    </a>
                </article>

            {{/foreach}}
            {{/get}}
        </div>
    </div>
    {{/post}}


</main>




<script>
(function() {
    const container = document.querySelector('.spite-screenshot');
    const images = Array.from(container.querySelectorAll('img'));

    // Shuffle images randomly
    for (let i = images.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [images[i], images[j]] = [images[j], images[i]];
    }

    // Re-append in shuffled order
    images.forEach(img => container.appendChild(img));

    // Reset active state to first (now random) image
    container.querySelectorAll('img').forEach((img, i) => {
        img.classList.toggle('active', i === 0);
    });

    let imageIndex = 0;
    const shuffledImages = container.querySelectorAll('img');

    function cycleImages() {
        if (shuffledImages.length <= 1) return;
        shuffledImages[imageIndex].classList.remove('active');
        imageIndex = (imageIndex + 1) % shuffledImages.length;
        shuffledImages[imageIndex].classList.add('active');
    }

    setInterval(cycleImages, 7000); // Cycle every 7 seconds
})();
</script>
