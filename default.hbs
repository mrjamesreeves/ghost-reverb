<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8">
    {{!-- `block "title"` lets individual templates override the <title>
         via {{#contentFor "title"}} — used by channel routes so they
         don't fall back to a bare site title. --}}
    <title>{{#block "title"}}{{meta_title}}{{/block}}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {{!-- Typekit serves all three families: Bebas Neue Pro (+ SemiExpanded),
         IBM Plex Serif, IBM Plex Sans. Preconnect starts the TLS
         handshake before the render-blocking stylesheet is requested. --}}
    <link rel="preconnect" href="https://use.typekit.net" crossorigin>
    <link rel="stylesheet" href="https://use.typekit.net/eer6kbs.css">
    <link rel="stylesheet" type="text/css" href="{{asset "css/zen.css"}}">

    {{ghost_head}}
</head>

<body class="{{body_class}}">

    {{!-- Wordmark + hover-reveal nav. Sits at the top of every page.
         Resting state: faint wordmark only. Hover (desktop) or tap
         (touch) reveals the full nav row. --}}
    {{> "nav"}}

    <main id="main" class="site-main">
        {{{body}}}
    </main>

    {{> "footer"}}

    {{> "signup-modal"}}

    {{!-- Smart quotes across all rendered content --}}
    <script src="{{asset "js/smartquotes.js"}}"></script>
    <script>smartquotes(); document.addEventListener('DOMContentLoaded', function () { smartquotes(document.body); });</script>

    <script src="{{asset "js/zen.js"}}"></script>

    {{ghost_foot}}
</body>
</html>
