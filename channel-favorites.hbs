{{!< default}}

{{!-- /favorites/ — Favorite Things channel. No landing page: renders the LATEST
     post in the tag as a full post, with the dial for everything else.
     Literal tag filter — {{#get}} can't interpolate route context. --}}

{{#contentFor "title"}}Favorite Things — {{@site.title}}{{/contentFor}}

{{!-- Mobile-only section heading — the dial (which carries the
     section title on desktop) is hidden below 1200px. --}}
<h1 class="channel-heading">Favorite Things</h1>

{{#get "posts" filter="tag:favorites" limit="all" order="published_at desc" include="tags"}}
  {{#foreach posts}}
    {{> "post-view" stacked=true}}
  {{/foreach}}
  {{> "dial" sectionTitle="Favorite Things" sectionUrl="/favorites/" numbered=true}}
{{/get}}
