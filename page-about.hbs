{{!< default}}

{{!-- /about/ — single-reader view.
     Portrait left, body right (scrolls). The body is rendered straight
     from the Ghost editor's content for this page — bio, press, CV,
     colophon all live in Ghost now, so the template stays thin.

     Image source:
       1. Page's feature_image (set in Ghost admin → About → "Image").
       2. Falls back to the bundled Oliver Farshi portrait so the page
          still renders if no feature image is set.

     Photo credit: set the page's feature_image_caption in Ghost admin
     ("Caption" field below the image). The shared partial drops it
     into the bottom-left corner, matching every other reader. --}}

<script>document.body.classList.add('has-archive-reader');</script>

{{#post}}

<main id="main" class="archive-page archive-page--single about-page">

  <div class="archive-reader archive-reader--single" id="archiveReader">

    <div class="archive-watermark archive-watermark--static">
      {{> "site-wordmark"}}
      <h1 class="archive-watermark-text">About</h1>
    </div>

    <article class="archive-entry is-active" data-slug="{{slug}}">

      <div class="archive-entry-image">
        {{!-- Portrait comes from the About page's feature_image in
             Ghost. No theme-side fallback — set the image in Ghost
             admin (Pages → About → cover image). --}}
        {{#if feature_image}}
          <img
            src="{{img_url feature_image size="xl"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="eager"
          />
        {{/if}}
        {{> "feature-image-caption"}}
      </div>

      <div class="archive-entry-content">
        <div class="archive-entry-text">
          <div class="archive-entry-body about-body">
            {{{content}}}
          </div>
        </div>
      </div>

    </article>

  </div>{{!-- /.archive-reader --}}

</main>

{{/post}}
