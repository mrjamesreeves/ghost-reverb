{{!< default}}

<script>document.body.classList.add('has-archive-reader', 'dreams-bg');</script>

<main id="main" class="archive-page dreams-page">

  {{#get "posts" filter="tag:dreams" limit="all"}}

  <!-- Ghosted watermark header -->
  <div class="archive-watermark">
    <h1>Dream<br>Inventory</h1>
  </div>

  <!-- Reader panel (65vh, 1000px max-width, entries stacked inside) -->
  <div class="archive-reader" id="archiveReader">
    {{#foreach posts}}
    <article class="archive-entry{{#if @first}} is-active{{/if}}" data-index="{{@index}}">

      <div class="archive-entry-image">
        {{#if feature_image}}
          <img
            srcset="{{img_url feature_image size="s"}} 600w, {{img_url feature_image size="m"}} 800w, {{img_url feature_image size="l"}} 1200w"
            sizes="50vw"
            src="{{img_url feature_image size="l"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="{{#if @first}}eager{{else}}lazy{{/if}}"
          />
        {{else}}
          <div class="archive-entry-no-image"></div>
        {{/if}}
      </div>

      <div class="archive-entry-content">
        <div class="archive-entry-inner">
          <div class="archive-entry-meta">
            <span class="archive-section-label">Dream Inventory</span>
            <time datetime="{{date format='YYYY-MM-DD'}}">{{date format="MMMM D, YYYY"}}</time>
          </div>
          <h2 class="archive-entry-title">
            <a href="{{url}}">{{title}}</a>
          </h2>
          {{#if custom_excerpt}}
            <p class="archive-entry-excerpt">{{custom_excerpt}}</p>
          {{/if}}
        </div>
      </div>

    </article>
    {{/foreach}}
  </div>

  <!-- Controls bar -->
  <div class="archive-controls" id="archiveControls">
    <button class="archive-toggle-index" id="archiveToggleIndex" aria-label="View all entries">
      <svg width="18" height="13" viewBox="0 0 18 13" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="0" y1="0.75" x2="18" y2="0.75" stroke="currentColor" stroke-width="1.5"/>
        <line x1="0" y1="6.75" x2="18" y2="6.75" stroke="currentColor" stroke-width="1.5"/>
        <line x1="0" y1="12.75" x2="18" y2="12.75" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </button>
    <div class="archive-nav-controls">
      <button class="archive-prev" id="archivePrev" aria-label="Previous entry" disabled>
        <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M7 1L1 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <span class="archive-counter" id="archiveCounter">1 / 1</span>
      <button class="archive-next" id="archiveNext" aria-label="Next entry">
        <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M1 1L7 7L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <!-- Index overlay -->
  <div class="archive-index-overlay" id="archiveIndex" aria-hidden="true">
    <div class="archive-index-header">
      <h1 class="archive-index-watermark">Dream<br>Inventory</h1>
      <button class="archive-index-close" id="archiveIndexClose" aria-label="Back to reader">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
    <div class="archive-index-list">
      {{#foreach posts}}
      <a class="archive-index-item" href="{{url}}">
        <span class="archive-index-title-text">{{title}}</span>
        <span class="archive-index-date">{{date format="MMM D, YYYY"}}</span>
      </a>
      {{/foreach}}
    </div>
    <nav class="archive-index-sitenav">
      <a href="{{@site.url}}/radio">Midnight Radio</a>
      <a href="{{@site.url}}/art-diary">Art Diary</a>
      <a href="{{@site.url}}/favorites">Favorite Things</a>
      <a href="{{@site.url}}/instructions">Instructions for Myself</a>
      <a href="{{@site.url}}/about">About</a>
    </nav>
  </div>

  {{/get}}

</main>

<script src="{{asset "js/archive-reader.js"}}"></script>
