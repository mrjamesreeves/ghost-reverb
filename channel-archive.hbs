{{!< default}}

{{!-- /archive/ — everything OUTSIDE the five sections (~650 posts),
     stacked like the other channels with the numbered dial. Comments
     are suppressed (hideComments): hundreds of comment containers
     would sink the page — readers comment on the single-post view.
     Literal negated tag filter — {{#get}} can't interpolate. --}}

{{#contentFor "title"}}Archive — {{@site.title}}{{/contentFor}}

{{!-- Mobile-only section heading — the dial (which carries the
     section title on desktop) is hidden below 1200px. --}}
<h1 class="channel-heading">Archive</h1>

{{#get "posts" filter="tag:-[midnight-radio,dreams,art-diary,favorites,public-works]" limit="all" order="published_at desc" include="tags"}}
  {{#foreach posts}}
    {{> "post-view" stacked=true hideComments=true}}
  {{/foreach}}
  {{> "dial" sectionTitle="Archive" sectionUrl="/archive/" numbered=true}}
{{/get}}
